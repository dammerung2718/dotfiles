#!/bin/sh
set -e # fail on error

# Config
################################################################################
BREW_PATH=/opt/homebrew
if test $(uname) = Linux; then
	BREW_PATH=/home/linuxbrew/.linuxbrew
fi


# Brew
################################################################################
if test ! -d $BREW_PATH; then
	NONINTERACTIVE=1 /bin/bash -c \
		"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$($BREW_PATH/bin/brew shellenv)"
brew bundle --cleanup


# Rust
#################################################################################
if test ! -d $HOME/.cargo; then
	curl https://sh.rustup.rs -sSf | sh -s -- -y
fi


# Dotfiles
#################################################################################
symlnk() {
	ln -sf $1 $2
}

mkdir -p $HOME/.config

symlnk $(pwd)/dot_shrc        $HOME/.zshrc
symlnk $(pwd)/dot_shrc        $HOME/.bashrc
symlnk $(pwd)/dot_vimrc       $HOME/.vimrc
symlnk $(pwd)/dot_config/nvim $HOME/.config/nvim
symlnk $(pwd)/dot_config/tmux $HOME/.config/tmux
